# Filled by `npx shopify app env pull` after linking a Partner app.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products
SHOPIFY_APP_URL=https://localhost

# SQLite by default (local + simple Docker volume). For Postgres, change
# prisma/schema.prisma provider to postgresql and set a Postgres URL.
DATABASE_URL=file:dev.sqlite

# Required for full AI generation inside Shopify Admin (standalone app)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Shopify Billing: use test charges on development stores (1=on, 0=off).
# Defaults to on when NODE_ENV is not production.
# Production App Store traffic must use BILLING_TEST_CHARGES=0.
BILLING_TEST_CHARGES=1

# Local only: skip Shopify Billing API and activate Pro in the app DB.
# Use this until Partner Dashboard → Distribution = Public.
# Ignored when NODE_ENV=production. Never set to 1 on a live host.
BILLING_DEV_BYPASS=0
