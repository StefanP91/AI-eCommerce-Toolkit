# Filled by `npx shopify app env pull` after linking a Partner app.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products
# Must be the Netlify Shopify PROXY site (shopify-proxy/), not marketing, not bare Render.
SHOPIFY_APP_URL=https://ai-commerce-suite-shopify.netlify.app

# PostgreSQL (Render Internal/External URL, or local Postgres).
# Example Render: postgresql://user:pass@dpg-xxxx-a/dbname
DATABASE_URL=

# Required for full AI generation inside Shopify Admin (standalone app)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Tried in order after GEMINI_MODEL hits 429. Each request starts at GEMINI_MODEL again.
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.0-flash

# When the host IP is geo-blocked by Gemini (common on some Render EU regions),
# route AI through the Netlify proxy instead of calling Google directly.
GEMINI_PROXY_URL=https://ai-ecommerce-suite.netlify.app/api/gemini
GEMINI_PROXY_SECRET=

# Shopify Billing: use test charges on development stores (1=on, 0=off).
# Defaults to on when NODE_ENV is not production.
# Production App Store traffic must use BILLING_TEST_CHARGES=0.
BILLING_TEST_CHARGES=1

# Local only: show Free/Pro toggle in Settings (no Shopify charges).
# Ignored when NODE_ENV=production. Never set to 1 on a live host.
# Upgrade always uses Shopify Billing API — bypass does NOT skip checkout.
BILLING_DEV_BYPASS=0

# Secret for GET /api/error-logs (used by scripts/pull-error-logs.mjs + GH Action).
# Set the same value on Render and as GitHub Actions secret LOG_EXPORT_SECRET.
LOG_EXPORT_SECRET=

# Comma-separated shops allowed to open /app/logs (owner-only).
# Accepts full domain or slug: ai-ecommerce-suite.myshopify.com OR ai-ecommerce-suite
# Leave empty so merchants never see the Logs UI.
LOG_VIEW_SHOPS=ai-ecommerce-suite.myshopify.com
